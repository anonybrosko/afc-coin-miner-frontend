// Upgrades.js
import React, { useContext, useState } from "react";
import { GameContext } from "./GameContext";

const Upgrades = () => {
  const { balance, upgrades, buyUpgrade } = useContext(GameContext);

  const [activeCategory, setActiveCategory] = useState("gpu");

  // Categories and their upgrades
  const categories = {
    gpu: [
      { name: "gpu1", label: "Nvidia RTX 4090", baseCost: 0.00000010, effect: 0.0000005, description: "Increases manual mining per click." },
      { name: "gpu2", label: "AMD RX 7900 XT", baseCost: 0.00000020, effect: 0.0000008, description: "High-end AMD GPU for clicks." },
    ],
    cpu: [
      { name: "cpu1", label: "Intel i9-13900K", baseCost: 0.00000015, effect: 0.0000003, description: "Increases manual mining slightly." },
      { name: "cpu2", label: "AMD Ryzen 9 7950X", baseCost: 0.00000018, effect: 0.0000004, description: "High-performance CPU for manual mining." },
    ],
    psu: [
      { name: "psu1", label: "Corsair AX1600i", baseCost: 0.00000500, effect: 0.0000015, energy: 0.00001, description: "Stable power supply boosts auto mining (limited per second)." },
      { name: "psu2", label: "EVGA SuperNOVA 1600 T2", baseCost: 0.00000800, effect: 0.000002, energy: 0.00002, description: "Powerful PSU allows faster auto mining temporarily." },
    ],
    network: [
      { name: "network1", label: "Network Boost", baseCost: 0.00002000, effect: 0.00001, duration: 60, description: "Temporarily increases all auto mining output for 60s." },
      { name: "network2", label: "Fiber Accelerator", baseCost: 0.00005000, effect: 0.00002, duration: 120, description: "Boosts auto mining output for 2 minutes." },
    ],
  };

  const currentUpgrades = categories[activeCategory];

  return (
    <div className="card">
      <h1>Upgrades</h1>

      {/* Sub-navbar */}
      <div style={{ display: "flex", marginBottom: 20 }}>
        {Object.keys(categories).map(cat => (
          <button
            key={cat}
            onClick={() => setActiveCategory(cat)}
            style={{
              flex: 1,
              padding: "10px 0",
              marginRight: 5,
              backgroundColor: activeCategory === cat ? "#4caf50" : "#ccc",
              color: activeCategory === cat ? "#fff" : "#000",
              border: "none",
              borderRadius: 4,
              cursor: "pointer"
            }}
          >
            {cat.toUpperCase()}
          </button>
        ))}
      </div>

      {/* Upgrades List */}
      {currentUpgrades.map(upg => {
        const level = upgrades[upg.name] || 0;
        const cost = upg.baseCost * Math.pow(2.5, level);
        const canBuy = balance >= cost;

        return (
          <div key={upg.name} style={{ marginBottom: 20 }}>
            <h2>{upg.label} (Level {level})</h2>
            <p style={{ fontSize: "0.9em" }}>{upg.description}</p>
            <p>Cost: {cost.toFixed(8)} AFC</p>
            <p>Effect: {upg.effect.toFixed(8)} {upg.type === "manual" ? "per click" : "per second"}</p>
            <button
              onClick={() => buyUpgrade(upg.name, cost)}
              className={`upgrade-button ${!canBuy ? "disabled" : ""}`}
            >
              {canBuy ? "Buy/Upgrade" : "Cannot Afford"}
            </button>
          </div>
        );
      })}
    </div>
  );
};

export default Upgrades;
