body {
  font-family: Arial, sans-serif;
  background: #0d0d0d;
  color: #f5f5f5;
  text-align: center;
  padding-top: 50px;
}

.container {
  max-width: 400px;
  margin: 0 auto;
  background: #1a1a1a;
  padding: 20px;
  border-radius: 12px;
  box-shadow: 0 0 20px #00ff99;
}

button {
  background: #00ff99;
  color: #000;
  font-size: 16px;
  padding: 10px 20px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  margin-top: 20px;
}

button:hover {
  background: #00cc77;
}
