/* General Body */
body {
  font-family: Arial, sans-serif;
  background: #0d0d0d;
  color: #f5f5f5;
  text-align: center;
  padding-top: 50px;
  margin: 0;
}

/* Headings */ 
h1 {
  font-size: 2.5rem;
  color: #00ff99;
  text-shadow: 2px 2px 5px #008844, 0 0 3px #00ff44;
  margin-bottom: 15px;
}

h2 {
  font-size: 2rem;
  color: #ffcc00;
  text-shadow: 2px 2px 5px #aa8800, 0 0 8px #ffcc00;
  margin-bottom: 12px;
}

/* Container for pages */
.container {
  max-width: 400px;
  margin: 50px auto;
  background: #1a1a1a;
  padding: 20px;
  border-radius: 12px;
  box-shadow: 0 0 20px #00ff99;
  color: #f5f5f5;
  text-align: center;
}

/* Desktop Default */
.container.desktop {
  max-width: 400px;
  margin: 0 auto;
  padding: 20px;
}

/* Mobile Adjustments */
.container.mobile {
  max-width: 90%;
  padding: 15px;
  font-size: 14px;
}

/* Buttons */
button {
  background: #00ff99;
  color: #000;
  font-size: 16px;
  padding: 10px 20px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  margin-top: 20px;
  box-shadow: 0 4px #00cc77;
  transition: all 0.1s ease-in-out;
}

button:hover {
  background: #00cc77;
  transform: translateY(2px);
  box-shadow: 0 2px #008844;
}

/* Prestige Button */
.prestige-button {
  background: #ffcc00;
  color: #000;
  font-size: 16px;
  padding: 10px 20px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  margin-top: 20px;
  box-shadow: 3px 3px 8px #ffaa00;
  font-weight: bold;
}

.prestige-button:hover {
  background: #ffaa00;
}

.prestige-button.disabled {
  background: #555;
  cursor: not-allowed;
  box-shadow: none;
}

/* Navigation Links */
.navbar {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-bottom: 20px;
}

/* Desktop Default */
.navbar.desktop {
  max-width: 400px;
  padding: 20px;
  margin: 0 auto;
}

.navbar.mobile {
  max-width: 90%;
  padding: 0 0 15px 15px ;
  font-size: 12px;
}

.navbar a {
  padding: 10px 20px;
  background-color: #00ff99;
  color: #000;
  text-decoration: none;
  border-radius: 8px;
  font-weight: bold;
  box-shadow: 0 4px #00cc77;
  transition: all 0.1s ease-in-out;
}

.navbar a:hover {
  transform: translateY(2px);
  box-shadow: 0 2px #008844;
}

/* Balance Display in top right */
.balance-display {
  position: absolute;
  top: 20px;
  right: 20px;
  font-weight: bold;
}
